# Environment: development | staging | production
# ENVIRONMENT is set in settings.yaml, not overridable via env

# sFTP Configuration (overrides settings.yaml)
SFTP_HOST=sftp.distributor.example.com
SFTP_PORT=22
SFTP_USERNAME=partner_user
SFTP_PASSWORD=changeme_use_key_auth
SFTP_PRIVATE_KEY_PATH=

# Application settings (overrides settings.yaml)
LOG_LEVEL=INFO
FILE_FORMAT=csv

# File Generation
DEFAULT_FILE_FORMAT=csv
FILE_ENCODING=utf-8

# Scheduling (cron expressions)
OUTBOUND_SCHEDULE_CRON=0 */2 * * *
INBOUND_SCHEDULE_CRON=*/15 * * * *

# Retry
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=30

# Logging
LOG_LEVEL=INFO
